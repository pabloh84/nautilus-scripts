#!/bin/bash

__DEBUG_LOG_FILE="$(basename "${BASH_SOURCE[0]}").log"
# shellcheck source=scripts/_debug_output
# source ~/scripts/_debug_output

# Source the script 'common-functions.sh'.
SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" &> /dev/null && pwd)
ROOT_DIR=$(grep --only-matching "^.*scripts[^/]*" <<< "$SCRIPT_DIR")
source "$ROOT_DIR/common-functions.sh"

# Initial checks
_main()
{
local input_files=$(_get_files "par_type=file; par_select_extension='m3u'")
local output_dir=""
_run_task_parallel "$input_files" "$output_dir"
_display_result_box "$output_dir"

}

_main_task() {
    local FILE=$1
    local OUTPUT_DIR=$2
    local OUTPUT_FILE
    local STD_OUTPUT
    local EXIT_CODE

    cp "$FILE" "$FILE".backup

    cat "$FILE".backup | sed '/^[^#]/ {s|[*]|-|g;s|:| -|g}' > "$FILE"

    # OUTPUT_FILE=$(echo "$FILE" | sed "s|[\*]|-|g;s|\:| -|g")
    # STD_OUTPUT=$(_transfer_file "m" "$FILE" "$OUTPUT_FILE" 2>&1)
    EXIT_CODE=$?
    # _log_error "$FILE" "$STD_OUTPUT" "$OUTPUT_DIR" "$EXIT_CODE" ""
}

_main "$@"
